# Optional: enables movie posters via TMDB. Get a free key at
# https://www.themoviedb.org/settings/api  (use the "API Key (v3 auth)" value)
TMDB_API_KEY=

# Optional: change the port (default 3000)
PORT=3000

# Optional: YTS API mirrors for the Browse tags, tried in order. The default
# already includes mirrors; reorder/add here if your ISP blocks them all.
# YTS_HOSTS=yts.mx,yts.am,yts.lt,yts.rs

# Optional: enables 1337x search by routing through a FlareSolverr container
# (solves Cloudflare). When using docker-compose this is set automatically.
# For a standalone run, point it at your FlareSolverr instance:
# FLARESOLVERR_URL=http://localhost:8191
